# ─────────────────────────────────────────────────────────────────────────────
# BookBot configuration. Copy this file to `.env` and fill in the values.
#   cp .env.example .env
# `.env` is gitignored — never commit your real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token_here
# Your Telegram numeric user id(s), comma-separated. Used for admin-only actions.
# Get it from @userinfobot (send /start to it).
ADMIN_IDS=123456789

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL, e.g. https://abcdefghijklm. supabase.co  (no trailing slash)
SUPABASE_URL=https://your-project-ref.supabase.co
# SERVICE-ROLE / SECRET key (bypasses RLS — keep it SECRET, never expose to clients).
SUPABASE_SERVICE_KEY=your-service-role-or-secret-key
# Storage bucket that holds the PDF files (created by the migration, name = 'books').
SUPABASE_BUCKET=books

# ── PDF web search ────────────────────────────────────────────────────────────
# PDFs are found via DuckDuckGo (the `ddgs` library) — NO API key required.

# ── Behaviour / tuning ────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=uz          # primary language ('uz'); English served on request
AUDIO_BITRATE_KBPS=48        # audio compression target (smaller = lighter files)
MAX_FILE_MB=50               # Telegram bot send cap (raise only if self-hosting Bot API)
CACHE_AUDIO_FILE_ID=true     # cache telegram file_id for audio (no file stored)
INGEST_DELAY_SECONDS=1.0     # polite delay between external downloads

# OpenAI — generates Uzbek book descriptions + genre (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Optional: proxy for Telegram if it is blocked on your network (VPN is simpler).
# HTTP works out of the box; SOCKS needs: pip install aiohttp_socks
# TELEGRAM_PROXY=socks5://127.0.0.1:1080

# ── Telethon fetcher (optional) ───────────────────────────────────────────────
# A USER account (not the bot) that searches book channels and forwards big files
# (up to 2 GB) into a private storage channel the bot then copies from — lifts the
# 50 MB send cap and skips slow web/YouTube fetches when the book is already on
# Telegram. Leave blank to disable (bot falls back to web/YouTube as before).
#   1. api_id/api_hash from https://my.telegram.org (use a SPARE account).
#   2. Run: python scripts/telethon_login.py  → paste the printed session below.
#   3. Make a PRIVATE channel; add the bot as admin + the userbot; put its id here.
#   4. List the book channels the userbot is joined to.
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION=
STORAGE_CHANNEL_ID=          # e.g. -1001234567890
SOURCE_CHANNELS=             # @kanal1,@kanal2,-1001112223334
